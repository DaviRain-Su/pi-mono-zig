{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "allowSyntheticDefaultImports": true,
    "paths": {
      "*": ["./*"],
      "@earendil-works/pi-agent-core": ["./types/pi-agent-core.d.ts"],
      "@earendil-works/pi-ai": ["./types/pi-ai.d.ts"],
      "@earendil-works/pi-tui": ["../tui/src/index.ts"],
      "@earendil-works/pi-tui/*": ["../tui/src/*"],
      "@mariozechner/pi-agent-core": ["./types/pi-agent-core.d.ts"],
      "@mariozechner/pi-ai": ["./types/pi-ai.d.ts"],
      "@mariozechner/pi-tui": ["../tui/src/index.ts"],
      "@mariozechner/pi-tui/*": ["../tui/src/*"]
    }
  },
  "include": ["src/**/*"]
}
